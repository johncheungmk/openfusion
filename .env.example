# Cloud providers and gateways
OPENAI_API_KEY=
OPENROUTER_API_KEY=
LITELLM_API_KEY=

# Local providers usually do not need a key. Set these only when your server requires one.
OLLAMA_API_KEY=
LMSTUDIO_API_KEY=

# Authentication for OpenFusion's own API. Replace before exposing the service.
OPENFUSION_API_KEY=replace-with-a-long-random-token
