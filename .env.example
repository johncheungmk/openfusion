# Cloud providers
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_PROXY_API_KEY=

# Local providers often do not need a key, but some OpenAI-compatible servers require a dummy one.
OLLAMA_API_KEY=
LMSTUDIO_API_KEY=

# Service auth for OpenFusion's own API. Replace this before exposing the server.
OPENFUSION_API_KEY=replace-with-a-long-random-token
